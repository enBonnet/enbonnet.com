---
export interface Props {
  title: string;
  text: string;
  ariaLabel: string;
  i18nTitle: string;
  i18nText: string;
}

const { title, text, ariaLabel, i18nTitle, i18nText } = Astro.props;
---

<section class="beat-card" data-i18n-attr={`aria-label:${ariaLabel}`} aria-label={title}>
  <span data-i18n={i18nTitle}>{title}</span>
  <p data-i18n={i18nText}>{text}</p>
</section>

<style>
  .beat-card {
    min-height: 11rem;
    grid-column: span 4;
    border: 1px solid transparent;
    border-radius: var(--radius);
    background:
      linear-gradient(180deg, rgba(29, 40, 31, 0.90), rgba(19, 27, 21, 0.92)) padding-box,
      linear-gradient(145deg, rgba(75, 234, 154, 0.25), rgba(191, 236, 200, 0.05) 55%, rgba(143, 255, 196, 0.0)) border-box;
    padding: clamp(1rem, 2.5vw, 1.65rem);
  }

  .beat-card span {
    display: block;
    margin-bottom: 0.7rem;
    color: var(--ink);
    font-size: 1.05rem;
    font-weight: 900;
    letter-spacing: -0.025em;
  }

  .beat-card p {
    color: var(--muted);
    line-height: 1.62;
  }

  @media (max-width: 980px) {
    .beat-card {
      grid-column: span 6;
    }
  }

  @media (max-width: 720px) {
    .beat-card {
      grid-column: 1;
    }
  }
</style>
