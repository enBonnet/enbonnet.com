---
import GlassCard from "./GlassCard.astro";

export interface Props {
  project: {
    name: string;
    eyebrow: string;
    description: string;
    links: Array<{ label: string; href: string }>;
    tags: string[];
    metric?: string;
    visual: string;
    layout: string;
  };
  index: number;
}

const { project, index } = Astro.props;
const visualMap: Record<string, string> = {
  rtk: `
    <div class="mini-window">
      <span></span><span></span><span></span>
      <code>useGetUserQuery()</code>
      <b>endpoint</b>
    </div>
    <div class="visual-arrow">-></div>
    <div class="map-pin"></div>
  `,
  routes: `
    <div class="route-tree">
      <span>/</span>
      <span class="indent">dashboard</span>
      <span class="indent more">projects/:id</span>
      <span class="indent more active">settings</span>
    </div>
  `,
  cli: `
    <div class="terminal-card">
      <span>$ migrazed supabase.json</span>
      <span>reading vscode tokens...</span>
      <span>writing zed theme...</span>
      <strong>done</strong>
    </div>
  `,
  mail: `
    <div class="mail-card">
      <span class="mail-row checked"></span>
      <span class="mail-row"></span>
      <span class="mail-row delete">Delete key</span>
    </div>
  `,
  catalog: `
    <div class="catalog-card">
      <span>UI</span><span>DX</span><span>CSS</span>
      <span>Icons</span><span>Docs</span><span>Tools</span>
    </div>
  `,
  bread: `
    <div class="formula-card">
      <strong>72%</strong>
      <span>hydration</span>
      <i>flour + water + time</i>
    </div>
  `,
};
const content = visualMap[project.visual] ?? "";
---

<article class={`project-card project-${project.layout} project-${project.visual}`}>
  <div class={`project-visual visual-${project.visual}`} aria-hidden="true" set:html={content} />
  <div class="project-body">
    <div class="project-topline">
      <span data-i18n={`p${index}Eyebrow`}>{project.eyebrow}</span>
      {project.metric && <strong data-i18n={`p${index}Metric`}>{project.metric}</strong>}
    </div>
    <h3>{project.name}</h3>
    <p data-i18n={`p${index}Desc`}>{project.description}</p>
    <ul class="tags" data-i18n-attr={`aria-label:p${index}TagAria`} aria-label={`${project.name} technologies`}>
      {project.tags.map((tag: string) => <li>{tag}</li>)}
    </ul>
    <div class="project-links">
      {
        project.links.map((link) => (
          <a href={link.href} target="_blank" rel="noreferrer">
            {link.label === "Site" ? <span data-i18n="linkSite">Site</span> : link.label}
          </a>
        ))
      }
    </div>
  </div>
</article>

<style>
  .project-card {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    gap: 1.1rem;
    height: 100%;
    align-content: stretch;
    border: 1px solid transparent;
    border-radius: var(--radius);
    background:
      linear-gradient(180deg, rgba(29, 40, 31, 0.90), rgba(19, 27, 21, 0.92)) padding-box,
      linear-gradient(145deg, rgba(75, 234, 154, 0.25), rgba(191, 236, 200, 0.05) 55%, rgba(143, 255, 196, 0.0)) border-box;
    padding: clamp(1rem, 2.5vw, 1.65rem);
  }

  .project-wide {
    grid-column: span 6;
    grid-row: span 9;
  }

  .project-tall {
    grid-column: span 4;
    grid-row: span 10;
  }

  .project-compact {
    grid-column: span 4;
    grid-row: span 8;
  }

  .project-catalog {
    grid-column: span 8;
    grid-row: span 6;
  }

  .project-visual {
    height: 100%;
    min-height: 11rem;
    border: 1px solid transparent;
    border-radius: calc(var(--radius) * 0.8);
    background:
      linear-gradient(90deg, rgba(143, 255, 196, 0.04) 1px, transparent 1px),
      linear-gradient(rgba(143, 255, 196, 0.03) 1px, transparent 1px),
      linear-gradient(180deg, rgba(7, 11, 8, 0.58), rgba(7, 11, 8, 0.58)) padding-box,
      linear-gradient(145deg, rgba(75, 234, 154, 0.15), rgba(191, 236, 200, 0.04) 55%, rgba(143, 255, 196, 0.0)) border-box;
    background-size: 24px 24px, 24px 24px, auto, auto;
    display: grid;
    place-items: center;
    padding: 1.1rem;
  }

  .project-wide .project-visual { min-height: 14rem; }
  .project-tall .project-visual,
  .project-compact .project-visual { min-height: 12.5rem; }
  .project-catalog .project-visual { min-height: 9rem; }

  .project-body {
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    justify-content: center;
  }

  .project-body p { margin-bottom: 0; }

  .project-topline {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.6rem;
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .project-topline strong {
    color: var(--faint);
    font-weight: 800;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tags li {
    padding: 0.32rem 0.55rem;
    border: 1px solid rgba(143, 255, 196, 0.18);
    border-radius: 999px;
    background: rgba(75, 234, 154, 0.08);
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: auto;
  }

  .project-links a {
    display: inline-flex;
    align-items: center;
    min-height: auto;
    padding: 0.5rem 0.7rem;
    border: 1px solid transparent;
    border-radius: 999px;
    background:
      rgba(8, 12, 9, 0.5) padding-box,
      linear-gradient(145deg, rgba(75, 234, 154, 0.14), rgba(191, 236, 200, 0.04) 55%, rgba(143, 255, 196, 0.0)) border-box;
    color: var(--accent-strong);
    font-size: 0.86rem;
    font-weight: 850;
    transition: background 160ms ease, transform 160ms ease;
  }

  .project-links a:hover {
    transform: translateY(-2px);
    background:
      rgba(75, 234, 154, 0.08) padding-box,
      linear-gradient(145deg, rgba(75, 234, 154, 0.22), rgba(191, 236, 200, 0.05) 55%, rgba(143, 255, 196, 0.0)) border-box;
  }

  /* Mini visuals */
  .mini-window {
    width: min(18rem, 100%);
    padding: 1rem;
    border: 1px solid transparent;
    border-radius: 0.4rem;
    background:
      #101611 padding-box,
      linear-gradient(145deg, rgba(75, 234, 154, 0.15), rgba(191, 236, 200, 0.04) 55%, rgba(143, 255, 196, 0.0)) border-box;
  }
  .mini-window span {
    display: inline-block;
    width: 0.45rem;
    height: 0.45rem;
    margin-right: 0.25rem;
    border-radius: 999px;
    background: var(--faint);
  }
  .mini-window code, .mini-window b { display: block; margin-top: 0.85rem; color: var(--accent-strong); }
  .mini-window b { width: max-content; padding: 0.25rem 0.5rem; border-radius: 999px; background: var(--accent-soft); font-size: 0.72rem; text-transform: uppercase; }

  .visual-rtk { grid-template-columns: 1fr auto 4rem; gap: 1rem; }
  .visual-arrow { color: var(--accent-strong); font-size: 1.5rem; font-weight: 900; }
  .map-pin { width: 3rem; height: 3rem; border: 0.7rem solid var(--accent-strong); border-radius: 50% 50% 50% 0; transform: rotate(-45deg); }

  .route-tree { display: grid; gap: 0.55rem; color: var(--muted); font-family: ui-monospace, SFMono-Regular, Consolas, monospace; }
  .route-tree span { padding: 0.55rem 0.65rem; border-left: 2px solid var(--line-strong); background: rgba(143, 255, 196, 0.06); }
  .route-tree .indent { margin-left: 1.4rem; }
  .route-tree .more { margin-left: 2.8rem; }
  .route-tree .active { color: #111712; background: var(--accent-strong); }

  .terminal-card { display: grid; gap: 0.7rem; padding: 1rem; border: 1px solid transparent; border-radius: 0.4rem; background: #090d0a padding-box, linear-gradient(145deg, rgba(75, 234, 154, 0.15), rgba(191, 236, 200, 0.04) 55%, rgba(143, 255, 196, 0.0)) border-box; color: var(--muted); font-family: ui-monospace, SFMono-Regular, Consolas, monospace; font-size: 0.86rem; }
  .terminal-card span:first-child, .terminal-card strong { color: var(--accent-strong); }

  .mail-card { display: grid; gap: 0.7rem; }
  .mail-row { display: block; height: 2.5rem; border: 1px solid transparent; border-radius: 0.35rem; background: linear-gradient(90deg, var(--line-strong) 0 18%, rgba(143, 255, 196, 0.05) 18%) padding-box, linear-gradient(145deg, rgba(75, 234, 154, 0.12), rgba(191, 236, 200, 0.03) 55%, rgba(143, 255, 196, 0.0)) border-box; }
  .mail-row.checked { background: linear-gradient(90deg, var(--accent-strong) 0 18%, rgba(143, 255, 196, 0.08) 18%) padding-box, linear-gradient(145deg, rgba(75, 234, 154, 0.22), rgba(191, 236, 200, 0.05) 55%, rgba(143, 255, 196, 0.0)) border-box; }
  .mail-row.delete { display: grid; place-items: center; background: rgba(255, 106, 106, 0.16) padding-box, linear-gradient(145deg, rgba(255, 106, 106, 0.14), rgba(191, 236, 200, 0.03) 55%, rgba(143, 255, 196, 0.0)) border-box; color: #ffc4c4; font-weight: 900; }

  .catalog-card { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.6rem; }
  .catalog-card span { display: grid; min-height: 3rem; place-items: center; border: 1px solid transparent; background: rgba(143, 255, 196, 0.07) padding-box, linear-gradient(145deg, rgba(75, 234, 154, 0.12), rgba(191, 236, 200, 0.03) 55%, rgba(143, 255, 196, 0.0)) border-box; color: var(--accent-strong); font-weight: 900; }

  .formula-card { display: grid; gap: 0.4rem; place-items: center; padding: 1.5rem; border: 1px solid transparent; background: rgba(240, 166, 74, 0.1) padding-box, linear-gradient(145deg, rgba(240, 166, 74, 0.22), rgba(191, 236, 200, 0.04) 55%, rgba(143, 255, 196, 0.0)) border-box; text-align: center; }
  .formula-card strong { color: var(--warm); font-size: 4rem; line-height: 0.9; letter-spacing: -0.08em; }
  .formula-card span { color: var(--ink); font-weight: 900; }
  .formula-card i { color: var(--muted); font-style: normal; }

  @media (max-width: 980px) {
    .project-wide,
    .project-tall,
    .project-compact,
    .project-catalog { grid-column: span 6; grid-row: auto; }
  }

  @media (max-width: 720px) {
    .project-wide,
    .project-tall,
    .project-compact,
    .project-catalog { grid-column: 1; grid-row: auto; }
    .visual-rtk { grid-template-columns: 1fr; }
    .visual-arrow { transform: rotate(90deg); }
  }
</style>
