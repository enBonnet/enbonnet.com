---
const siteUrl = "https://enbonnet.com";
const pageTitle = "QR - Ender Bonnet";
const pageDescription = "Scan this QR code to find Ender Bonnet across the internet.";
const socialImage = `${siteUrl}/logo-edge-less.png`;

const qrJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: `${siteUrl}/qr`,
  image: socialImage,
};
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>(function(){try{var l=localStorage.getItem('enbonnet-lang');if(l)document.documentElement.lang=l}catch(e){}})();</script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/600-green.svg" />
    <link rel="canonical" href={`${siteUrl}/qr`} />
    <title data-i18n="qrPageTitle">{pageTitle}</title>
    <meta name="description" data-i18n="qrPageDescription" content={pageDescription} />
    <meta name="author" content="Ender Bonnet" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#101310" />
    <meta property="og:title" data-i18n="qrPageTitle" content={pageTitle} />
    <meta property="og:description" data-i18n="qrPageDescription" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}/qr`} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@enbonnet" />
    <meta name="twitter:title" data-i18n="qrPageTitle" content={pageTitle} />
    <meta name="twitter:description" data-i18n="qrPageDescription" content={pageDescription} />
    <meta name="twitter:image" content={socialImage} />
    <script type="application/ld+json" set:html={JSON.stringify(qrJsonLd)}></script>
  </head>
  <body>
    <main class="qr-page">
      <a class="back-link" href="/" data-i18n="qrBack">← Back</a>
      <section class="qr-card">
        <p class="kicker" data-i18n="qrKicker">Scan</p>
        <h1 data-i18n="qrTitle">Find me across the internet.</h1>
        <p class="qr-subtitle" data-i18n="qrSubtitle">Point your camera at the code to open my social links.</p>
        <div class="qr-wrapper">
          <img class="qr-image" src="/qr-social.svg" alt="QR code for enbonnet.com/social" width="280" height="280" />
        </div>
        <a class="qr-link" href="/social" data-i18n="qrOpenLink">Or open /social directly →</a>
      </section>
    </main>
    <script is:inline src="/i18n.js"></script>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --bg: #101310;
    --paper: #172018;
    --paper-soft: #1d281f;
    --paper-strong: #263529;
    --ink: #f6fff7;
    --muted: #afc8b5;
    --faint: #71927a;
    --line: rgba(191, 236, 200, 0.22);
    --line-strong: rgba(191, 236, 200, 0.42);
    --accent: #4bea9a;
    --accent-strong: #8fffc4;
    --accent-soft: rgba(75, 234, 154, 0.12);
    --radius: 0.35rem;
    --gap: 0.75rem;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color: var(--ink);
    caret-color: var(--accent);
  }

  body {
    min-height: 100dvh;
    margin: 0;
    background:
      linear-gradient(rgba(246, 255, 247, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(246, 255, 247, 0.02) 1px, transparent 1px),
      radial-gradient(circle at 18% 0%, rgba(75, 234, 154, 0.14), transparent 32rem),
      linear-gradient(180deg, #121812 0%, #0b0e0c 100%);
    background-size: 28px 28px, 28px 28px, auto, auto;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:focus-visible {
    outline: 3px solid rgba(143, 255, 196, 0.7);
    outline-offset: 4px;
  }

  .back-link {
    position: fixed;
    top: 1.25rem;
    left: 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(8, 12, 9, 0.6);
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
    z-index: 10;
  }

  .back-link:hover {
    border-color: var(--accent-strong);
    color: var(--accent-strong);
    background: rgba(75, 234, 154, 0.08);
  }

  .qr-page {
    width: min(520px, calc(100% - 32px));
    padding: 2rem 0;
  }

  .qr-card {
    position: relative;
    overflow: hidden;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background:
      radial-gradient(circle at 72% 12%, rgba(75, 234, 154, 0.16), transparent 14rem),
      linear-gradient(180deg, rgba(29, 40, 31, 0.98), rgba(15, 20, 16, 0.98));
  }

  .qr-card::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    background: repeating-linear-gradient(0deg, rgba(246, 255, 247, 0.025) 0 1px, transparent 1px 5px);
    mix-blend-mode: screen;
  }

  .kicker {
    margin: 0 0 0.85rem;
    color: var(--accent);
    font-size: 0.73rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 14ch;
    margin: 0 0 0.65rem;
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    line-height: 0.9;
    letter-spacing: -0.07em;
  }

  .qr-subtitle {
    margin: 0 0 2rem;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.55;
  }

  .qr-wrapper {
    display: flex;
    justify-content: center;
    border: 3px solid var(--accent);
    border-radius: var(--radius);
    background: #ffffff;
    margin-bottom: 2rem;
  }

  .qr-image {
    display: block;
    width: 100%;
    height: auto;
  }

  .qr-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.65rem 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(8, 12, 9, 0.45);
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease, color 160ms ease;
  }

  .qr-link:hover {
    transform: translateY(-2px);
    border-color: var(--accent-strong);
    color: var(--accent-strong);
    background: rgba(75, 234, 154, 0.07);
  }

  @media (max-width: 520px) {
    .back-link {
      position: static;
      margin-bottom: 1.25rem;
    }

    body {
      justify-content: flex-start;
      padding-top: 1.5rem;
    }
  }
</style>