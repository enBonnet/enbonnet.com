const siteUrl = "https://enbonnet.com";
const pageTitle = "Social - Ender Bonnet";
const pageDescription = "Find Ender Bonnet across the internet. GitHub, LinkedIn, X, Bluesky, Mastodon, and email.";
const socialImage = `${siteUrl}/logo-edge-less.png`;

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Ender Bonnet",
  url: siteUrl,
  image: socialImage,
  jobTitle: "Software Engineer",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Santiago",
    addressCountry: "CL",
  },
  sameAs: socials.filter((s) => s.label !== "Email").map((s) => s.href),
  email: "ender@enbonnet.com",
  knowsAbout: [
    "Software engineering",
    "Frontend development",
    "Developer tools",
    "VSCode extensions",
    "Browser extensions",
    "CLI tools",
    "Editor themes",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>(function(){try{var l=localStorage.getItem('enbonnet-lang');if(l)document.documentElement.lang=l}catch(e){}})();</script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/600-green.svg" />
    <link rel="canonical" href={`${siteUrl}/social`} />
    <title data-i18n="socialPageTitle">{pageTitle}</title>
    <meta name="description" data-i18n="socialPageDescription" content={pageDescription} />
    <meta name="author" content="Ender Bonnet" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#101310" />
    <meta property="og:title" data-i18n="socialPageTitle" content={pageTitle} />
    <meta property="og:description" data-i18n="socialPageDescription" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}/social`} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@enbonnet" />
    <meta name="twitter:title" data-i18n="socialPageTitle" content={pageTitle} />
    <meta name="twitter:description" data-i18n="socialPageDescription" content={pageDescription} />
    <meta name="twitter:image" content={socialImage} />
    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)}></script>
  </head>
  <body>
    <main class="social-page">
      <a class="back-link" href="/" data-i18n="socialBack">← Back</a>
      <section class="social-card">
        <p class="kicker" data-i18n="socialKicker">Connect</p>
        <img class="social-logo" src="/600-green.svg" alt="Ender Bonnet logo" width="56" height="56" />
        <h1 data-i18n="socialTitle">Find me across the internet.</h1>
        <p class="social-subtitle" data-i18n="socialSubtitle">GitHub, LinkedIn, X, Bluesky, Mastodon, and email.</p>
        <ul class="social-list">
          {socials.map((social) => (
            <li>
              <a class="social-link" href={social.href} target={social.label === "Email" ? undefined : "_blank"} rel={social.label === "Email" ? undefined : "noreferrer"}>
                <span class="social-icon" set:html={social.icon} />
                <span class="social-label">{social.label === "Email" ? "ender@enbonnet.com" : social.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <script is:inline src="/i18n.js"></script>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --bg: #101310;
    --paper: #172018;
    --paper-soft: #1d281f;
    --paper-strong: #263529;
    --ink: #f6fff7;
    --muted: #afc8b5;
    --faint: #71927a;
    --line: rgba(191, 236, 200, 0.22);
    --line-strong: rgba(191, 236, 200, 0.42);
    --accent: #4bea9a;
    --accent-strong: #8fffc4;
    --accent-soft: rgba(75, 234, 154, 0.12);
    --radius: 0.35rem;
    --gap: 0.75rem;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color: var(--ink);
    caret-color: var(--accent);
  }

  body {
    min-height: 100dvh;
    margin: 0;
    background:
      radial-gradient(circle at 18% 0%, rgba(75, 234, 154, 0.10), transparent 32rem),
      linear-gradient(180deg, #121812 0%, #0b0e0c 100%);
    color: var(--ink);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:focus-visible {
    outline: 3px solid rgba(143, 255, 196, 0.7);
    outline-offset: 4px;
  }

  .back-link {
    position: fixed;
    top: 1.25rem;
    left: 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.75rem;
    border: 1px solid transparent;
    border-radius: 999px;
    background:
      rgba(8, 12, 9, 0.6) padding-box,
      linear-gradient(145deg, rgba(75, 234, 154, 0.12), rgba(191, 236, 200, 0.03) 55%, rgba(143, 255, 196, 0.0)) border-box;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
    z-index: 10;
  }

  .back-link:hover {
    color: var(--accent-strong);
    background:
      rgba(75, 234, 154, 0.08) padding-box,
      linear-gradient(145deg, rgba(75, 234, 154, 0.20), rgba(191, 236, 200, 0.05) 55%, rgba(143, 255, 196, 0.0)) border-box;
  }

  .social-page {
    width: min(520px, calc(100% - 32px));
    padding: 2rem 0;
  }

  .social-card {
    position: relative;
    overflow: hidden;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border: 1px solid transparent;
    border-radius: var(--radius);
    background:
      radial-gradient(circle at 72% 12%, rgba(75, 234, 154, 0.10), transparent 14rem) padding-box,
      linear-gradient(180deg, rgba(29, 40, 31, 0.92), rgba(15, 20, 16, 0.92)) padding-box,
      linear-gradient(145deg, rgba(75, 234, 154, 0.18), rgba(191, 236, 200, 0.04) 55%, rgba(143, 255, 196, 0.0)) border-box;
  }

  .kicker {
    margin: 0 0 0.85rem;
    color: var(--accent);
    font-size: 0.73rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 14ch;
    margin: 0 0 0.65rem;
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    line-height: 0.9;
    letter-spacing: -0.07em;
  }

  .social-logo {
    display: block;
    width: 3.5rem;
    height: 3.5rem;
    margin: 0 0 1rem;
  }

  .social-subtitle {
    margin: 0 0 2rem;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.55;
  }

  .social-list {
    display: grid;
    gap: 0.65rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.85rem 1.1rem;
    border: 1px solid transparent;
    border-radius: var(--radius);
    background:
      rgba(8, 12, 9, 0.45) padding-box,
      linear-gradient(145deg, rgba(75, 234, 154, 0.10), rgba(191, 236, 200, 0.03) 55%, rgba(143, 255, 196, 0.0)) border-box;
    transition: transform 160ms ease, background 160ms ease;
  }

  .social-link:hover {
    transform: translateY(-2px);
    background:
      rgba(75, 234, 154, 0.07) padding-box,
      linear-gradient(145deg, rgba(75, 234, 154, 0.18), rgba(191, 236, 200, 0.05) 55%, rgba(143, 255, 196, 0.0)) border-box;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.65rem;
    height: 1.65rem;
    flex-shrink: 0;
    color: var(--accent-strong);
    filter: drop-shadow(0 0 0.45rem rgba(75, 234, 154, 0.28));
  }

  .social-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .social-label {
    color: var(--ink);
    font-size: 0.95rem;
    font-weight: 850;
    letter-spacing: -0.01em;
  }

  .social-link:hover .social-label {
    color: var(--accent-strong);
  }

  @media (max-width: 520px) {
    .back-link {
      position: static;
      margin-bottom: 1.25rem;
    }

    body {
      justify-content: flex-start;
      padding-top: 1.5rem;
    }
  }
</style>