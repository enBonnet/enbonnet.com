---
const siteUrl = "https://enbonnet.com";
const pageTitle = "404 - Page Not Found | Ender Bonnet";
const pageDescription = "This page doesn't exist. Find Ender Bonnet elsewhere on the internet.";
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>(function(){try{var l=localStorage.getItem('enbonnet-lang');if(l)document.documentElement.lang=l}catch(e){}})();</script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/600-green.svg" />
    <title data-i18n="error404Title">{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="noindex, follow" />
    <meta name="theme-color" content="#101310" />
  </head>
  <body>
    <main class="error-page">
      <a class="back-link" href="/" data-i18n="socialBack">← Back</a>
      <section class="error-card">
        <p class="kicker" data-i18n="error404Kicker">Error 404</p>
        <pre class="error-ascii glitch-text" aria-hidden="true">
    ╔════════════════════════╗
    ║   ░░░ LOADING █░░░░░  ║
    ║   ██████████░░░░░░░░  ║
    ╚════════════════════════╝
      ┌─────────┐
      │  █   █  │
      │  ◠   ◡  │
      │    ─    │
      │ ─────── │
      │ ┌─────┐ │
      └─────────┘
        </pre>
        <h1 class="glitch-title" data-i18n="error404Title">Page not found.</h1>
        <p class="error-subtitle" data-i18n="error404Subtitle">This page vanished into the void. Maybe it never existed, or maybe it's hiding somewhere else.</p>
        <a class="error-link" href="/" data-i18n="error404Cta">Go home</a>
      </section>
    </main>
    <script is:inline src="/i18n.js"></script>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --bg: #101310;
    --paper: #172018;
    --paper-soft: #1d281f;
    --paper-strong: #263529;
    --ink: #f6fff7;
    --muted: #afc8b5;
    --faint: #71927a;
    --line: rgba(191, 236, 200, 0.22);
    --line-strong: rgba(191, 236, 200, 0.42);
    --accent: #4bea9a;
    --accent-strong: #8fffc4;
    --accent-soft: rgba(75, 234, 154, 0.12);
    --radius: 0.35rem;
    --gap: 0.75rem;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color: var(--ink);
    caret-color: var(--accent);
  }

  body {
    min-height: 100dvh;
    margin: 0;
    background:
      linear-gradient(rgba(246, 255, 247, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(246, 255, 247, 0.02) 1px, transparent 1px),
      radial-gradient(circle at 18% 0%, rgba(75, 234, 154, 0.14), transparent 32rem),
      linear-gradient(180deg, #121812 0%, #0b0e0c 100%);
    background-size: 28px 28px, 28px 28px, auto, auto;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:focus-visible {
    outline: 3px solid rgba(143, 255, 196, 0.7);
    outline-offset: 4px;
  }

  .back-link {
    position: fixed;
    top: 1.25rem;
    left: 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(8, 12, 9, 0.6);
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
    z-index: 10;
  }

  .back-link:hover {
    border-color: var(--accent-strong);
    color: var(--accent-strong);
    background: rgba(75, 234, 154, 0.08);
  }

  .error-page {
    width: min(520px, calc(100% - 32px));
    padding: 2rem 0;
  }

  .error-card {
    position: relative;
    overflow: hidden;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background:
      radial-gradient(circle at 72% 12%, rgba(75, 234, 154, 0.16), transparent 14rem),
      linear-gradient(180deg, rgba(29, 40, 31, 0.98), rgba(15, 20, 16, 0.98));
  }

  .error-card::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    background: repeating-linear-gradient(0deg, rgba(246, 255, 247, 0.025) 0 1px, transparent 1px 5px);
    mix-blend-mode: screen;
  }

  .kicker {
    margin: 0 0 0.85rem;
    color: var(--accent);
    font-size: 0.73rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    position: relative;
  }

  h1 {
    max-width: 14ch;
    margin: 0 0 0.65rem;
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    line-height: 0.9;
    letter-spacing: -0.07em;
  }

  .error-ascii {
    position: relative;
    margin: 0 0 1.5rem;
    color: var(--accent);
    font-size: clamp(0.45rem, 1.1vw, 0.72rem);
    line-height: 1.35;
    letter-spacing: 0.02em;
    white-space: pre;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;
    animation: glitch-flicker 3.5s steps(1, end) infinite;
  }

  .error-ascii::before,
  .error-ascii::after {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: none;
    content: attr(data-content);
  }

  .error-ascii::before {
    color: rgba(143, 255, 196, 0.7);
    animation: glitch-shift-red 2.8s steps(1, end) infinite;
    clip-path: inset(20% 0 60% 0);
    transform: translateX(0);
  }

  .error-ascii::after {
    color: rgba(255, 106, 106, 0.5);
    animation: glitch-shift-blue 3.2s steps(1, end) infinite;
    clip-path: inset(60% 0 10% 0);
    transform: translateX(0);
  }

  .error-subtitle {
    margin: 0 0 1.75rem;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.55;
  }

  .error-ascii + h1 {
    margin-top: 0;
  }

  .glitch-title {
    position: relative;
  }

  .glitch-title::before,
  .glitch-title::after {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: none;
    content: attr(data-text);
  }

  .glitch-title::before {
    color: rgba(143, 255, 196, 0.7);
    animation: glitch-text-shift 2.6s steps(1, end) infinite;
    clip-path: inset(0 0 65% 0);
  }

  .glitch-title::after {
    color: rgba(255, 106, 106, 0.5);
    animation: glitch-text-shift-alt 3.1s steps(1, end) infinite;
    clip-path: inset(55% 0 0 0);
  }

  .error-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.3rem;
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    background: rgba(75, 234, 154, 0.08);
    color: var(--accent-strong);
    font-size: 0.95rem;
    font-weight: 850;
    letter-spacing: -0.01em;
    transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
    position: relative;
  }

  .error-link:hover {
    transform: translateY(-2px);
    border-color: var(--accent-strong);
    background: rgba(75, 234, 154, 0.14);
  }

  @keyframes glitch-flicker {
    0%, 88%, 91%, 93%, 95%, 100% { opacity: 1; }
    89% { opacity: 0.72; }
    92% { opacity: 0.85; }
    94% { opacity: 0.65; }
  }

  @keyframes glitch-shift-red {
    0%, 74%, 78%, 100% { transform: translateX(0); }
    75% { transform: translateX(6px, -1px) skewX(-3deg); }
    76% { transform: translateX(-4px, 1px) skewX(2deg); }
    77% { transform: translateX(2px) skewX(-1deg); }
  }

  @keyframes glitch-shift-blue {
    0%, 60%, 64%, 100% { transform: translateX(0); }
    61% { transform: translateX(-8px, 2px) skewX(4deg); }
    62% { transform: translateX(5px, -1px) skewX(-2deg); }
    63% { transform: translateX(-3px) skewX(1deg); }
  }

  @keyframes glitch-text-shift {
    0%, 70%, 74%, 100% { transform: translateX(0); }
    71% { transform: translateX(5px, -2px) skewX(-4deg); }
    72% { transform: translateX(-3px, 1px) skewX(2deg); }
    73% { transform: translateX(2px) skewX(-1deg); }
  }

  @keyframes glitch-text-shift-alt {
    0%, 55%, 59%, 100% { transform: translateX(0); }
    56% { transform: translateX(-7px, 2px) skewX(3deg); }
    57% { transform: translateX(4px, -1px) skewX(-2deg); }
    58% { transform: translateX(-2px) skewX(1deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .error-ascii,
    .error-ascii::before,
    .error-ascii::after,
    .glitch-title::before,
    .glitch-title::after {
      animation: none;
    }

    .error-ascii::before,
    .error-ascii::after,
    .glitch-title::before,
    .glitch-title::after {
      opacity: 0;
    }
  }

  @media (max-width: 520px) {
    .back-link {
      position: static;
      margin-bottom: 1.25rem;
    }

    body {
      justify-content: flex-start;
      padding-top: 1.5rem;
    }
  }
</style>

<script is:inline>
  (function() {
    var ascii = document.querySelector('.error-ascii');
    if (ascii) {
      ascii.setAttribute('data-content', ascii.textContent);
    }
    var title = document.querySelector('.glitch-title');
    if (title) {
      title.setAttribute('data-text', title.textContent);
    }
  })();
</script>