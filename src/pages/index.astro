  .glitch-logo {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    width: 100%;
    aspect-ratio: 1;
  }

  .glitch-logo::before,
  .glitch-logo::after {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    content: "";
  }

  .glitch-logo::before {
    background: repeating-linear-gradient(0deg, rgba(246, 255, 247, 0.12) 0 1px, transparent 1px 7px);
    mix-blend-mode: overlay;
    opacity: 0.22;
    animation: glitch-scan 2.6s steps(8, end) infinite;
  }

  .glitch-logo::after {
    background: linear-gradient(90deg, transparent, rgba(143, 255, 196, 0.3), transparent);
    opacity: 0;
    transform: translateX(-130%);
    animation: glitch-flash 5.5s steps(1, end) infinite;
  }

  .glitch-logo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .glitch-logo-base {
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 0 1.1rem rgba(75, 234, 154, 0.14));
  }

  .glitch-logo-alt {
    z-index: 2;
    opacity: 0;
    mix-blend-mode: lighten;
    animation: glitch-alt 4.8s steps(1, end) infinite;
  }

  .glitch-logo-slice {
    z-index: 3;
    opacity: 0;
    mix-blend-mode: screen;
  }

  .slice-one {
    clip-path: inset(14% 0 67% 0);
    filter: hue-rotate(115deg) saturate(1.8);
    animation: glitch-slice-one 3.4s steps(1, end) infinite;
  }

  .slice-two {
    clip-path: inset(58% 0 28% 0);
    filter: hue-rotate(300deg) saturate(1.7);
    animation: glitch-slice-two 4.1s steps(1, end) infinite;
  }

  @keyframes glitch-alt {
    0%, 76%, 80%, 100% {
      opacity: 0;
      transform: translate(0);
    }
    77% {
      opacity: 0.72;
      transform: translate(-8px, 3px);
    }
    78% {
      opacity: 0.36;
      transform: translate(7px, -2px);
    }
    79% {
      opacity: 0.62;
      transform: translate(-3px, 0);
    }
  }

  @keyframes glitch-slice-one {
    0%, 63%, 66%, 100% {
      opacity: 0;
      transform: translate(0);
    }
    64% {
      opacity: 0.82;
      transform: translate(16px, -3px) skewX(8deg);
    }
    65% {
      opacity: 0.45;
      transform: translate(-12px, 2px) skewX(-5deg);
    }
  }

  @keyframes glitch-slice-two {
    0%, 42%, 45%, 100% {
      opacity: 0;
      transform: translate(0);
    }
    43% {
      opacity: 0.75;
      transform: translate(-18px, 3px);
    }
    44% {
      opacity: 0.42;
      transform: translate(10px, -2px);
    }
  }

  @keyframes glitch-scan {
    0% { transform: translateY(-12%); }
    100% { transform: translateY(12%); }
  }

  @keyframes glitch-flash {
    0%, 82%, 100% {
      opacity: 0;
      transform: translateX(-130%);
    }
    83% {
      opacity: 0.34;
      transform: translateX(120%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .glitch-logo::before,
    .glitch-logo::after,
    .glitch-logo-alt,
    .glitch-logo-slice {
      animation: none;
