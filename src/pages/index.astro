---
const socials = [
  { label: "GitHub", href: "https://github.com/enbonnet" },
  { label: "LinkedIn", href: "https://linkedin.com/in/enbonnet" },
  { label: "Bluesky", href: "https://bsky.app/profile/enbonnet.com" },
  { label: "Reddit", href: "https://www.reddit.com/user/enbonnet/" },
];

const featuredProjects = [
  {
    name: "RTK Map Hook Navigator",
    eyebrow: "VSCode Extension",
    description:
      "Connects generated RTK Query hooks back to endpoint definitions with CodeLens annotations and Go to Definition support.",
    image: "/images/rtk-map.png",
    imageAlt: "RTK Map Hook Navigator extension screenshot",
    links: [
      { label: "Marketplace", href: "https://marketplace.visualstudio.com/items?itemName=enbonnet.rtk-map" },
      { label: "Open VSX", href: "https://open-vsx.org/extension/enBonnet/rtk-map" },
      { label: "GitHub", href: "https://github.com/enBonnet/rtk-map" },
    ],
    tags: ["TypeScript", "RTK Query", "CodeLens", "DX"],
    metric: "313 Open VSX downloads",
  },
  {
    name: "Routes React Router",
    eyebrow: "VSCode Extension",
    description:
      "Annotates React Router route files with full derived paths from nested route definitions, making large route configs easier to scan.",
    image: "/images/routes-react-router-screenshot.png",
    imageAlt: "Routes React Router extension screenshot",
    links: [
      { label: "Marketplace", href: "https://marketplace.visualstudio.com/items?itemName=enbonnet.routes-react-router" },
      { label: "Open VSX", href: "https://open-vsx.org/extension/enBonnet/routes-react-router" },
      { label: "GitHub", href: "https://github.com/enBonnet/routes-react-router" },
    ],
    tags: ["TypeScript", "React Router", "VSCode", "Frontend"],
    metric: "1,066 Open VSX downloads",
  },
  {
    name: "Migrazed",
    eyebrow: "CLI Tool",
    description:
      "Converts VSCode color themes into Zed-compatible theme files, preserving semantic highlighting, syntax tokens, terminal colors, and light/dark variants.",
    links: [{ label: "GitHub", href: "https://github.com/enBonnet/migrazed" }],
    tags: ["TypeScript", "CLI", "Themes", "Zed"],
    metric: "6 GitHub stars",
  },
  {
    name: "Deletudo",
    eyebrow: "Browser Extension",
    description:
      "A keyboard-first extension for deleting email conversations faster in Gmail, Outlook, and Migadu without leaving the keyboard.",
    image: "/images/deletudo-store-screenshot.png",
    imageAlt: "Deletudo browser extension store screenshot",
    links: [
      { label: "Chrome", href: "https://chromewebstore.google.com/detail/deletudo/aojjacdnefgogmkmigpdgbfimfjfpghn?hl=en" },
      { label: "Firefox", href: "https://addons.mozilla.org/en-US/firefox/addon/deletudo/" },
      { label: "GitHub", href: "https://github.com/enBonnet/deletudo" },
    ],
    tags: ["JavaScript", "Chrome", "Firefox", "Productivity"],
  },
  {
    name: "Frontend Tools",
    eyebrow: "Open Source",
    description:
      "A community-curated collection of frontend development tools, design resources, browser extensions, UI libraries, and learning references.",
    image: "/images/frontend-tools-screenshot.png",
    imageAlt: "Frontend Tools project screenshot",
    links: [{ label: "GitHub", href: "https://github.com/enBonnet/Frontend-Tools" }],
    tags: ["Open Source", "Frontend", "Resources", "Community"],
    metric: "152 stars / 27 forks",
  },
  {
    name: "Il Pane",
    eyebrow: "Web Product",
    description:
      "A recipe tool for crafting and sharing bread formulas, including hydration calculations based on ingredient absorption and user adjustments.",
    image: "/images/ilpane-screenshot.png",
    imageAlt: "Il Pane web application screenshot",
    links: [
      { label: "Site", href: "https://ilpane.lat" },
      { label: "GitHub", href: "https://github.com/enbonnet/ilpane" },
    ],
    tags: ["TypeScript", "React Router", "Product", "Food"],
  },
];

const themes = [
  { name: "Supabase Theme", installs: "5,391", marketplace: "492", openVsx: "4,899", href: "https://supabase.enbonnet.com", color: "#3ecf8e" },
  { name: "Orange Flavor", installs: "2,897", marketplace: "219", openVsx: "2,678", href: "https://orange.enbonnet.com", color: "#f47c20" },
  { name: "TanStack Theme", installs: "1,141", marketplace: "247", openVsx: "894", href: "https://tanstack.enbonnet.com", color: "#50b195" },
  { name: "Orange Ocean", installs: "1,124", marketplace: "185", openVsx: "939", href: "https://ocean.enbonnet.com", color: "#ff8a3d" },
  { name: "Bumble Coffee", installs: "1,098", marketplace: "156", openVsx: "942", href: "https://bumble.enbonnet.com", color: "#f4a020" },
  { name: "Humans Theme", installs: "660", marketplace: "42", openVsx: "618", href: "https://humans.enbonnet.com", color: "#e95421" },
  { name: "Svelte Theme", installs: "526", marketplace: "84", openVsx: "442", href: "https://svelte.enbonnet.com", color: "#ff3c00" },
  { name: "Green Night", installs: "436", marketplace: "16", openVsx: "420", href: "https://green.enbonnet.com", color: "#4bea9a" },
  { name: "Lilo Theme", installs: "344", marketplace: "26", openVsx: "318", href: "https://lilo.enbonnet.com", color: "#3de5e8" },
];

const themesByInstalls = [...themes].sort(
  (a, b) => Number(b.installs.replace(/,/g, "")) - Number(a.installs.replace(/,/g, "")),
);

const smallTools = [
  { name: "Gira", description: "A Go CLI for managing Jira tasks from the terminal.", href: "https://github.com/enBonnet/gira" },
  { name: "img2pdf-cli", description: "A Python CLI for converting images into PDFs with batching and image processing options.", href: "https://github.com/enBonnet/img2pdf-cli" },
  { name: "Terminal theme ports", description: "Color schemes and ports for Warp, Ghostty, and other editor/terminal environments.", href: "https://github.com/enBonnet?tab=repositories&q=theme" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/logo-edge-less.svg" />
    <title>Ender Bonnet - Software Engineer</title>
    <meta
      name="description"
      content="Software engineer building developer tools, editor extensions, browser extensions, and focused web products."
    />
    <meta name="keywords" content="Ender Bonnet, Software Engineer, Frontend, Developer Tools, VSCode Extensions, Open VSX, Browser Extensions" />
    <meta property="og:title" content="Ender Bonnet - Software Engineer" />
    <meta property="og:description" content="Developer tools, editor extensions, browser extensions, and focused web products." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://enbonnet.com" />
    <meta property="og:image" content="https://enbonnet.com/logo-edge-less.png" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Ender Bonnet - Software Engineer" />
    <meta name="twitter:description" content="Developer tools, editor extensions, browser extensions, and focused web products." />
    <meta name="twitter:image" content="https://enbonnet.com/logo-edge-less.png" />
  </head>
  <body>
    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="shell hero-grid">
          <div class="hero-copy">
            <p class="kicker">Frontend and software engineer based in Santiago, Chile</p>
            <h1 id="hero-title">I build practical developer tools and focused web products.</h1>
            <p class="hero-lede">
              I am Ender Bonnet, currently working at <a href="https://www.lilohq.com/" target="_blank" rel="noreferrer">Lilo</a>.
              My work spans VSCode extensions, published editor themes, browser extensions, CLIs, and small products that solve real workflow problems.
            </p>
            <div class="hero-actions" aria-label="Primary links">
              <a class="button primary" href="#work">View work</a>
              <a class="button" href="https://github.com/enbonnet" target="_blank" rel="noreferrer">GitHub</a>
            </div>
          </div>

          <aside class="hero-card" aria-label="Portfolio highlights">
            <picture>
              <img src="/600-green-bg.svg" alt="Ender Bonnet logo" width="160" height="160" />
            </picture>
            <div class="stat-grid">
              <div>
                <strong>9</strong>
                <span>Published themes</span>
              </div>
              <div>
                <strong>13.6k+</strong>
                <span>Combined theme installs/downloads</span>
              </div>
              <div>
                <strong>2</strong>
                <span>VSCode dev extensions on Open VSX</span>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section class="section intro-strip" aria-label="What I build">
        <div class="shell strip-grid">
          <div>
            <span>Developer experience</span>
            <p>Extensions that make framework-specific workflows easier to navigate.</p>
          </div>
          <div>
            <span>Editor design systems</span>
            <p>Published themes across VSCode Marketplace and Open VSX.</p>
          </div>
          <div>
            <span>Workflow utilities</span>
            <p>Small browser and CLI tools built around everyday friction.</p>
          </div>
        </div>
      </section>

      <section class="section" id="work" aria-labelledby="work-title">
        <div class="shell section-heading">
          <p class="kicker">Selected work</p>
          <h2 id="work-title">Projects with shipped surfaces.</h2>
          <p>
            A focused mix of editor extensions, open-source resources, browser tooling, and product experiments.
          </p>
        </div>

        <div class="shell project-grid">
          {featuredProjects.map((project) => (
            <article class="project-card">
              {project.image && <img class="project-image" src={project.image} alt={project.imageAlt} loading="lazy" />}
              <div class="project-body">
                <div class="project-topline">
                  <span>{project.eyebrow}</span>
                  {project.metric && <strong>{project.metric}</strong>}
                </div>
                <h3>{project.name}</h3>
                <p>{project.description}</p>
                <ul class="tags" aria-label={`${project.name} technologies`}>
                  {project.tags.map((tag) => <li>{tag}</li>)}
                </ul>
                <div class="project-links">
                  {project.links.map((link) => (
                    <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section themes" aria-labelledby="themes-title">
        <div class="shell theme-panel">
          <div class="theme-copy">
            <p class="kicker">Editor theme system</p>
            <h2 id="themes-title">9 published VSCode-compatible themes.</h2>
            <p>
              A family of themes distributed through VSCode Marketplace and Open VSX for VSCode, VSCodium, Cursor, Windsurf, and compatible editors.
            </p>
            <div class="theme-stats" aria-label="Theme distribution stats">
              <div><strong>13.6k+</strong><span>Combined installs/downloads</span></div>
              <div><strong>12.1k+</strong><span>Open VSX downloads</span></div>
              <div><strong>Verified</strong><span>Open VSX publisher</span></div>
            </div>
          </div>

          <div class="theme-list">
            {themesByInstalls.map((theme) => (
              <a class="theme-row" href={theme.href} target="_blank" rel="noreferrer" style={`--accent: ${theme.color}`}>
                <span class="theme-dot" aria-hidden="true"></span>
                <span class="theme-name">{theme.name}</span>
                <span class="theme-count">{theme.installs}</span>
                <span class="theme-detail">VS Marketplace {theme.marketplace} / Open VSX {theme.openVsx}</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="small-tools-title">
        <div class="shell section-heading compact">
          <p class="kicker">Also built</p>
          <h2 id="small-tools-title">Small tools and experiments.</h2>
        </div>
        <div class="shell small-grid">
          {smallTools.map((tool) => (
            <a class="small-card" href={tool.href} target="_blank" rel="noreferrer">
              <h3>{tool.name}</h3>
              <p>{tool.description}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="section contact" aria-labelledby="contact-title">
        <div class="shell contact-card">
          <div>
            <p class="kicker">Contact</p>
            <h2 id="contact-title">Reach me on the internet.</h2>
          </div>
          <div class="socials">
            {socials.map((social) => (
              <a href={social.href} target="_blank" rel="noreferrer">{social.label}</a>
            ))}
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --bg: #171c19;
    --surface: #1d2520;
    --surface-strong: #2d332f;
    --ink: #fafffb;
    --muted: #b9d6c3;
    --line: rgba(95, 255, 192, 0.16);
    --accent: #4bea9a;
    --accent-strong: #6dffc9;
    --accent-soft: rgba(75, 234, 154, 0.14);
    --leaf: #7fc99b;
    --bloom: #ff8db5;
    --shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color: var(--ink);
    caret-color: var(--accent);
    scroll-behavior: smooth;
  }

  ::selection {
    background: #2d3831;
    color: #fafffb;
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      radial-gradient(circle at 12% 10%, rgba(75, 234, 154, 0.18), transparent 26rem),
      radial-gradient(circle at 86% 22%, rgba(255, 141, 181, 0.1), transparent 18rem),
      radial-gradient(ellipse at 50% -10%, rgba(127, 201, 155, 0.18), transparent 34rem),
      repeating-linear-gradient(90deg, rgba(75, 234, 154, 0.045) 0 1px, transparent 1px 5.5rem),
      linear-gradient(180deg, #171c19 0%, #101411 48rem, var(--bg) 100%);
    color: var(--ink);
  }

  body::before {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    content: "";
    background:
      radial-gradient(ellipse at 18% 72%, rgba(127, 201, 155, 0.14), transparent 15rem),
      radial-gradient(ellipse at 80% 78%, rgba(95, 255, 192, 0.1), transparent 18rem),
      linear-gradient(115deg, transparent 0 46%, rgba(75, 234, 154, 0.08) 46% 47%, transparent 47% 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 86%, transparent 100%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:focus-visible {
    outline: 3px solid rgba(75, 234, 154, 0.65);
    outline-offset: 4px;
    border-radius: 0.5rem;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .shell {
    width: min(1120px, calc(100% - 32px));
    margin-inline: auto;
  }

  .hero {
    padding: 6rem 0 4rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.65fr);
    gap: 2rem;
    align-items: stretch;
  }

  .hero-copy,
  .hero-card,
  .project-card,
  .theme-panel,
  .contact-card,
  .small-card,
  .intro-strip .shell > div {
    border: 1px solid var(--line);
    background: rgba(29, 37, 32, 0.82);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .hero-copy {
    padding: clamp(2rem, 6vw, 4.5rem);
    border-radius: 2rem;
  }

  .kicker {
    margin: 0 0 1rem;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 11ch;
    margin-bottom: 1.5rem;
    font-size: clamp(3.4rem, 10vw, 6.8rem);
    line-height: 0.88;
    letter-spacing: -0.08em;
  }

  h2 {
    margin-bottom: 0.85rem;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.96;
    letter-spacing: -0.055em;
  }

  h3 {
    margin-bottom: 0.75rem;
    font-size: 1.35rem;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .hero-lede {
    max-width: 680px;
    margin-bottom: 2rem;
    color: var(--muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.65;
  }

  .hero-lede a,
  .project-links a,
  .socials a {
    color: var(--accent-strong);
    font-weight: 800;
  }

  .hero-actions,
  .project-links,
  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .button,
  .project-links a,
  .socials a {
    display: inline-flex;
    align-items: center;
    min-height: 2.75rem;
    padding: 0.8rem 1rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface-strong);
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .button.primary {
    border-color: var(--accent-strong);
    background: var(--accent-strong);
    color: #171c19;
  }

  .button:hover,
  .project-links a:hover,
  .socials a:hover,
  .small-card:hover,
  .theme-row:hover {
    transform: translateY(-2px);
    border-color: rgba(75, 234, 154, 0.55);
  }

  .hero-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem;
    border-radius: 2rem;
    background:
      radial-gradient(circle at 28% 18%, rgba(95, 255, 192, 0.24), transparent 11rem),
      linear-gradient(155deg, rgba(45, 56, 49, 0.96) 0%, rgba(23, 28, 25, 0.96) 100%);
  }

  .hero-card img {
    width: 10rem;
    height: 10rem;
    object-fit: contain;
  }

  .stat-grid {
    display: grid;
    gap: 1rem;
  }

  .stat-grid div,
  .theme-stats div {
    padding-top: 1rem;
    border-top: 1px solid rgba(95, 255, 192, 0.18);
  }

  .stat-grid strong,
  .theme-stats strong {
    display: block;
    font-size: 2rem;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .stat-grid span,
  .theme-stats span {
    display: block;
    margin-top: 0.35rem;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .section {
    padding: 4rem 0;
  }

  .intro-strip {
    padding-top: 0;
  }

  .strip-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .intro-strip .shell > div {
    padding: 1.5rem;
    border-radius: 1.25rem;
    box-shadow: none;
  }

  .intro-strip span {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 850;
  }

  .intro-strip p,
  .section-heading p,
  .project-card p,
  .theme-copy p,
  .small-card p {
    color: var(--muted);
    line-height: 1.65;
  }

  .intro-strip p,
  .project-card p,
  .small-card p {
    margin-bottom: 0;
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 1.5rem;
  }

  .section-heading.compact {
    margin-bottom: 1rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .project-card {
    display: grid;
    grid-template-rows: auto 1fr;
    overflow: hidden;
    border-radius: 1.5rem;
    box-shadow: none;
  }

  .project-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-bottom: 1px solid var(--line);
    background: var(--accent-soft);
  }

  .project-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
  }

  .project-topline {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-topline strong {
    color: var(--muted);
    font-weight: 750;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tags li {
    padding: 0.38rem 0.62rem;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 750;
  }

  .project-links {
    margin-top: auto;
  }

  .project-links a {
    min-height: auto;
    padding: 0.55rem 0.75rem;
    font-size: 0.9rem;
  }

  .themes {
    background: #101411;
    color: #fafffb;
  }

  .theme-panel {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 2rem;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border-color: rgba(255, 255, 255, 0.12);
    border-radius: 2rem;
    background:
      radial-gradient(circle at top left, rgba(75, 234, 154, 0.26), transparent 28rem),
      radial-gradient(circle at bottom right, rgba(255, 141, 181, 0.12), transparent 20rem),
      #171c19;
    box-shadow: none;
  }

  .theme-copy p {
    color: var(--muted);
  }

  .theme-stats {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }

  .theme-stats div {
    border-color: rgba(255, 255, 255, 0.14);
  }

  .theme-stats span {
    color: var(--muted);
  }

  .theme-list {
    display: grid;
    gap: 0.7rem;
  }

  .theme-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.85rem;
    align-items: center;
    padding: 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    background: rgba(250, 255, 251, 0.055);
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .theme-row:hover {
    background: rgba(75, 234, 154, 0.09);
    border-color: color-mix(in srgb, var(--accent) 70%, white 20%);
  }

  .theme-dot {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 0.3rem color-mix(in srgb, var(--accent) 22%, transparent);
  }

  .theme-name,
  .theme-count {
    font-weight: 850;
  }

